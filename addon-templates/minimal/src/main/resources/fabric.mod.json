{
  "schemaVersion": 1,
  "id": "Ampere-minimal-addon-template",
  "version": "${version}",
  "name": "Ampere Minimal Addon Template",
  "description": "Small Ampere Client addon example: one module, one macro action, and one macro condition.",
  "authors": [
    "You"
  ],
  "custom": {
    "Ampere:color": "80,220,120",
    "modmenu": {
      "parent": {
        "id": "Ampere"
      }
    }
  },
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.example.minimal.MinimalInit"
    ],
    "Ampere": [
      "com.example.minimal.MinimalAddon"
    ]
  },
  "depends": {
    "java": ">=25",
    "minecraft": "${mc_compat}",
    "fabricloader": ">=0.18.4",
    "fabric-api": "*",
    "Ampere": ">=2.3"
  }
}
