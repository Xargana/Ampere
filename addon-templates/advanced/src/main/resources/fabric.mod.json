{
  "schemaVersion": 1,
  "id": "Ampere-advanced-addon-template",
  "version": "${version}",
  "name": "Ampere Advanced",
  "description": "Reference addon for Ampere Client: a module, macro action, preset, condition, command, HUD element, and event hook.",
  "authors": [
    "You"
  ],
  "custom": {
    "Ampere:color": "255,80,80",
    "modmenu": {
      "parent": {
        "id": "Ampere"
      }
    }
  },
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.example.addon.ExampleInit"
    ],
    "Ampere": [
      "com.example.addon.ExampleAddon"
    ]
  },
  "mixins": [
    "Ampere-advanced-addon-template.mixins.json"
  ],
  "depends": {
    "java": ">=25",
    "minecraft": "${mc_compat}",
    "fabricloader": ">=0.18.4",
    "fabric-api": "*",
    "Ampere": ">=2.3"
  }
}
